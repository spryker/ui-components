{
    "name": "file-uploader",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "libs/file-uploader/src",
    "prefix": "spy",
    "projectType": "library",
    "release": {
        "version": {
            "manifestRootsToUpdate": ["dist/{projectRoot}"],
            "currentVersionResolver": "git-tag",
            "fallbackCurrentVersionResolver": "disk"
        }
    },
    "tags": [],
    "targets": {
        "build": {
            "executor": "@nx/angular:package",
            "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
            "options": {
                "project": "libs/file-uploader/ng-package.json",
                "tsConfig": "libs/file-uploader/tsconfig.lib.json"
            },
            "configurations": {
                "production": {
                    "tsConfig": "libs/file-uploader/tsconfig.lib.prod.json"
                },
                "development": {}
            },
            "defaultConfiguration": "production"
        },
        "nx-release-publish": {
            "options": {
                "packageRoot": "dist/{projectRoot}"
            }
        },
        "test": {
            "executor": "@nx/jest:jest",
            "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
            "options": {
                "jestConfig": "libs/file-uploader/jest.config.ts",
                "tsConfig": "libs/file-uploader/tsconfig.spec.json"
            }
        },
        "lint": {
            "executor": "@nx/eslint:lint"
        },
        "storybook": {
            "executor": "@storybook/angular:start-storybook",
            "options": {
                "port": 4400,
                "configDir": "libs/file-uploader/.storybook",
                "browserTarget": "file-uploader:build-storybook",
                "compodoc": true,
                "compodocArgs": ["-e", "json", "-d", "dist"],
                "enableProdMode": false,
                "styles": [".storybook/styles.less"]
            },
            "configurations": {
                "ci": {
                    "quiet": true
                }
            }
        },
        "build-storybook": {
            "executor": "@storybook/angular:build-storybook",
            "outputs": ["{options.outputPath}"],
            "options": {
                "outputDir": "dist/storybook/file-uploader",
                "configDir": "libs/file-uploader/.storybook",
                "browserTarget": "file-uploader:build-storybook",
                "compodoc": true,
                "compodocArgs": ["-e", "json", "-d", "dist"],
                "enableProdMode": false,
                "styles": [".storybook/styles.less"]
            },
            "configurations": {
                "ci": {
                    "quiet": true
                }
            }
        }
    }
}
